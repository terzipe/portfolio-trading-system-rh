# Robinhood credentials
RH_USERNAME=your_robinhood_email@example.com
RH_PASSWORD=your_robinhood_password

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Trading parameters
ACCOUNT_BUDGET=66000                # total capital to deploy
MAX_POSITION_PCT=0.20               # max single position as fraction of budget
MIN_DTE=45                          # minimum days-to-expiry for options
MAX_DAILY_LOSS_PCT=0.05             # daily drawdown stop (5%)

# iMessage alert recipient (your own number or email registered to iMessage)
IMESSAGE_RECIPIENT=+1XXXXXXXXXX
